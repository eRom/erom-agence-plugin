{
  "$schema": "https://designtokens.org/schemas/2025.10/format.json",

  "color": {
    "$type": "color",
    "$description": "Dark mode - mode par defaut, gris chauds hue 24-30",

    "background":              { "$value": "{neutral.dark-bg}" },
    "foreground":              { "$value": "{neutral.dark-fg}" },
    "card":                    { "$value": "{neutral.dark-card}" },
    "card-foreground":         { "$value": "{neutral.dark-card-fg}" },
    "card-border":             { "$value": "{neutral.dark-card-border}" },
    "popover":                 { "$value": "{neutral.dark-popover}" },
    "popover-foreground":      { "$value": "{neutral.dark-popover-fg}" },
    "popover-border":          { "$value": "{neutral.dark-popover-border}" },
    "primary":                 { "$value": "{brand.amber}" },
    "primary-foreground":      { "$value": "{brand.amber-foreground}" },
    "secondary":               { "$value": "{neutral.dark-secondary}" },
    "secondary-foreground":    { "$value": "{neutral.dark-secondary-fg}" },
    "muted":                   { "$value": "{neutral.dark-muted}" },
    "muted-foreground":        { "$value": "{neutral.dark-muted-fg}" },
    "accent":                  { "$value": "{neutral.dark-accent}" },
    "accent-foreground":       { "$value": "{neutral.dark-accent-fg}" },
    "destructive":             { "$value": "{destructive.default}" },
    "destructive-foreground":  { "$value": "{destructive.foreground}" },
    "border":                  { "$value": "{neutral.dark-border}" },
    "input":                   { "$value": "{neutral.dark-input}" },
    "ring":                    { "$value": "{brand.amber}" },

    "sidebar":                    { "$value": "{neutral.dark-sidebar}" },
    "sidebar-foreground":         { "$value": "{neutral.dark-sidebar-fg}" },
    "sidebar-primary":            { "$value": "{brand.amber}" },
    "sidebar-primary-foreground": { "$value": "{brand.amber-foreground}" },
    "sidebar-accent":             { "$value": "{neutral.dark-sidebar-accent}" },
    "sidebar-accent-foreground":  { "$value": "{neutral.dark-sidebar-accent-fg}" },
    "sidebar-border":             { "$value": "{neutral.dark-sidebar-border}" },
    "sidebar-ring":               { "$value": "{brand.amber}" },

    "chart-1": { "$value": "{chart.dark.1}" },
    "chart-2": { "$value": "{chart.dark.2}" },
    "chart-3": { "$value": "{chart.dark.3}" },
    "chart-4": { "$value": "{chart.dark.4}" },
    "chart-5": { "$value": "{chart.dark.5}" }
  },

  "elevate": {
    "$type": "color",
    "1":              { "$value": "{elevate.dark.1}" },
    "2":              { "$value": "{elevate.dark.2}" },
    "button-outline": { "$value": "{elevate.dark.button-outline}" },
    "badge-outline":  { "$value": "{elevate.dark.badge-outline}" }
  },

  "shadow": {
    "$type": "shadow",
    "2xs":     { "$value": "{shadow.dark.2xs}" },
    "xs":      { "$value": "{shadow.dark.xs}" },
    "sm":      { "$value": "{shadow.dark.sm}" },
    "default": { "$value": "{shadow.dark.default}" },
    "md":      { "$value": "{shadow.dark.md}" },
    "lg":      { "$value": "{shadow.dark.lg}" },
    "xl":      { "$value": "{shadow.dark.xl}" },
    "2xl":     { "$value": "{shadow.dark.2xl}" }
  }
}
