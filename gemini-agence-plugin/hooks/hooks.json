{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${GEMINI_PLUGIN_ROOT}/hooks/nlm-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$GEMINI_PLUGIN_ROOT/hooks/redact-context.ts\""
          }
        ]
      }
    ],
    "MessageDisplay": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$GEMINI_PLUGIN_ROOT/hooks/redact-display.ts\""
          }
        ]
      }
    ]
  }
}
