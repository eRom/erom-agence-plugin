{
  "mcpServers": {
    "erom-slack-mcp": {
      "type": "stdio",
      "command": "bun",
      "args": ["run", "${CASERNE_SLACK_MCP_SERVER}"],
      "env": {
        "SLACK_BOT_TOKEN": "${CLAUDE_SLACK_BOT_TOKEN}"
      }
    },
    "cortex-mcp": {
      "type": "stdio",
      "command": "bun",
      "args": ["run", "${CASERNE_VAULT_MCP_SERVER}"]
    }
  }
}
