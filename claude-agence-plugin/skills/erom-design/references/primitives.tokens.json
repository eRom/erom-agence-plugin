  "easing": {
    "$type": "cubicBezier",
    "ease-out": {
      "$value": [0, 0, 0.58, 1],
      "$description": "Sidebar collapse, panneau lateral"
    },
    "ease-in-out": {
      "$value": [0.25, 0.1, 0.25, 1],
